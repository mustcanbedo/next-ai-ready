{
  "name": "@next-ai-ready/next",
  "version": "0.1.0-alpha.2",
  "description": "Next.js plugin, route handlers, build CLI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./handlers/llms-txt": {
      "types": "./dist/handlers/llms-txt.d.ts",
      "import": "./dist/handlers/llms-txt.js"
    },
    "./handlers/llms-full": {
      "types": "./dist/handlers/llms-full.d.ts",
      "import": "./dist/handlers/llms-full.js"
    },
    "./handlers/page-md": {
      "types": "./dist/handlers/page-md.d.ts",
      "import": "./dist/handlers/page-md.js"
    },
    "./handlers/page-ai-json": {
      "types": "./dist/handlers/page-ai-json.d.ts",
      "import": "./dist/handlers/page-ai-json.js"
    },
    "./handlers/openapi": {
      "types": "./dist/handlers/openapi.d.ts",
      "import": "./dist/handlers/openapi.js"
    },
    "./handlers/tools": {
      "types": "./dist/handlers/tools.d.ts",
      "import": "./dist/handlers/tools.js"
    },
    "./handlers/action": {
      "types": "./dist/handlers/action.d.ts",
      "import": "./dist/handlers/action.js"
    },
    "./handlers/mcp": {
      "types": "./dist/handlers/mcp.d.ts",
      "import": "./dist/handlers/mcp.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@next-ai-ready/actions": "workspace:*",
    "@next-ai-ready/core": "workspace:*",
    "@next-ai-ready/llms": "workspace:*",
    "@next-ai-ready/mcp": "workspace:*",
    "@next-ai-ready/mdx": "workspace:*",
    "@next-ai-ready/openapi": "workspace:*",
    "@next-ai-ready/semantic": "workspace:*",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mcp-handler": "^1.0.0",
    "next": ">=14.2.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "mcp-handler": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
